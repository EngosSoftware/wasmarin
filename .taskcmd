.tasks

  .audit
    .desc Checks for vulnerabilities
    .cmd cargo audit

  .build
    .desc Builds in debug mode
    .cmd cargo build

  .clean
    .desc Cleans all targets
    .cmd cargo clean
    .cmd rm -rf ./manual/book

  .clippy
    .desc Runs clippy for all targets
    .cmd cargo +nightly clippy --all-targets

  .cov
    .desc Generates code coverage report in text format
    .cmd cargo llvm-cov clean
    .cmd cargo llvm-cov --no-cfg-coverage

  .cov-html
    .desc Generates code coverage report in HTML format
    .cmd cargo llvm-cov clean
    .cmd cargo llvm-cov --no-cfg-coverage --html

  .cov-html-open
    .desc Generates code coverage report in HTML format and opens in browser
    .cmd cargo llvm-cov clean
    .cmd cargo llvm-cov --no-cfg-coverage --html --open

  .cov-badge
    .desc Generates the detailed code coverage badge
    .cmd cargo llvm-cov clean
    .cmd cargo llvm-cov --no-cfg-coverage --json --summary-only | coverio --collapse --tag cov-badge

  .doc
    .desc Generates documentation
    .cmd cargo doc

  .doc-private
    .desc Generates documentation
    .cmd cargo doc --document-private-items

  .doc-open
    .desc Generates documentation and opens in browser
    .cmd cargo doc --open

  .doc-private-open
    .desc Generates documentation and opens in browser
    .cmd cargo doc --open --document-private-items

  .fmt
    .desc Runs code formatter
    .cmd cargo +nightly fmt

  .manual
    .desc Builds the manual from Markdown files
    .cmd mdbook build
      .dir manual

  .readme
    .desc Recreates README file
    .cmd magg readme
    .task cov-badge

  .serve
    .desc Serves manual locally and rebuilds on changes
    .cmd mdbook serve
      .dir manual

  .test
    .desc Runs tests in debug mode
    .cmd cargo test

  .testn
    .desc Runs tests in debug mode
    .cmd cargo nextest run
